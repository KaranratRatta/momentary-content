# ─── API Keys ───────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your keys:
#   cp .env.example .env
# `.env` is gitignored and never committed.

# FAL API key — image generation (https://fal.ai/dashboard/keys)
# Format: app-id:secret
FAL_KEY=

# OpenRouter API key — LLM scene-prompt generation (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
